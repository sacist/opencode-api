{
  "name": "opencode-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "init": "tsx src/scripts/init.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:restart": "docker compose restart",
    "docker:build": "docker compose build",
    "docker:sudo:up": "sudo docker compose up -d --build",
    "docker:sudo:down": "sudo docker compose down",
    "docker:sudo:logs": "sudo docker compose logs -f",
    "docker:sudo:restart": "sudo docker compose restart",
    "docker:sudo:build": "sudo docker compose build"
  },
  "imports": {
    "#config/*": "./dist/config/*.js",
    "#classes/*": "./dist/classes/*.js",
    "#errors/*": "./dist/errors/*.js",
    "#middleware/*": "./dist/middleware/*.js",
    "#helpers/*": "./dist/helpers/*.js",
    "#repositories/*": "./dist/repositories/*.js",
    "#modules/*": "./dist/modules/*.js",
    "#scripts/*": "./dist/scripts/*.js",
    "#types/*": "./dist/types/*.js"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.17.15",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "pino": "^9.5.0",
    "pino-roll": "^3.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.5",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}