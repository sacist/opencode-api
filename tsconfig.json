{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "paths": {
      "#config/*": [
        "./src/config/*"
      ],
      "#classes/*": [
        "./src/classes/*"
      ],
      "#errors/*": [
        "./src/errors/*"
      ],
      "#middleware/*": [
        "./src/middleware/*"
      ],
      "#helpers/*": [
        "./src/helpers/*"
      ],
      "#repositories/*": [
        "./src/repositories/*"
      ],
      "#modules/*": [
        "./src/modules/*"
      ],
      "#scripts/*": [
        "./src/scripts/*"
      ],
      "#types/*": [
        "./src/types/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}